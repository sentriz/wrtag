#!/bin/sh

set -e

PUID=${PUID:-0}
PGID=${PGID:-0}
USERNAME=wrtag

[ "$PUID" -eq 0 ] && exec "$@"

adduser -D -u "$PUID" -g "$PGID" "$USERNAME" 2>/dev/null || true

if [ -n "$WRTAG_WEB_DB_PATH" ]; then
    db_dir=$(dirname "$WRTAG_WEB_DB_PATH")
    mkdir -p "$db_dir"
    chown "$PUID:$PGID" "$db_dir"
    [ -f "$WRTAG_WEB_DB_PATH" ] && chown "$PUID:$PGID" "$WRTAG_WEB_DB_PATH"
fi

exec su-exec "$PUID:$PGID" "$@"
